    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = np.arange(-10, 11)\n",
    "y = 5 * x + 3\n",
    "\n",
    "plt.plot(x, y, marker='o')\n",
    "plt.title('y = 5x + 3')\n",
    "plt.xlabel('x')\n",
    "plt.ylabel('y')\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
