     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "A = np.full((5,5),3)\n",
    "\n",
    "B = A ** 2\n",
    "\n",
    "print(A)\n",
    "print(B)"
   ]
  }
