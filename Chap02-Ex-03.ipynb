   "source": [
    "要素がすべて3の5行5列の行列を作成し、その行列を2乗する計算をする。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "db5e3c73",
   "metadata": {},
   "outputs": [
