   "source": [
    "関数 f(x) = (x+1)^2 を、\n",
    "x=0 から x=2 まで積分する"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6fc79567",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "answer_5_15 積分値: 8.666666666666668\n",
      "answer_5_15 推定誤差: 9.621932880084691e-14\n"
     ]
    }
   ],
   "source": [
    "from scipy import integrate\n",
    "\n",
    "answer_5_15 = integrate.quad(lambda x: (x + 1)**2, 0, 2)\n",
    "\n",
    "print(\"answer_5_15 積分値:\", answer_5_15[0])\n",
    "print(\"answer_5_15 推定誤差:\", answer_5_15[1])"
   ]
  }
 ],
