    "# 練習問題 5-17\n",
    "from scipy.optimize import fsolve\n",
    "\n",
    "def f(x):\n",
    "    return 5*x - 10\n",
    "\n",
    "answer_5_17 = fsolve(f, 0)\n",
    "\n",
    "print(\"answer_5_17:\")\n",
    "print(answer_5_17)\n",
    "\n",
    "print(\"f(answer_5_17):\")\n",
    "print(f(answer_5_17))"
   ]
