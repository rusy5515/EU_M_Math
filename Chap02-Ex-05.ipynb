   "source": [
    "import numpy as np\n",
    "\n",
    "A = np.array([\n",
    "    [1, 2, 3],\n",
    "    [1, 3, 2],\n",
    "    [3, 1, 2]\n",
    "])\n",
    "\n",
    "A_inv = np.linalg.inv(A)\n",
    "\n",
    "print(A_inv)\n",
    "eigenvalues, eigenvectors = np.linalg.eig(A)\n",
    "\n",
    "print(\"固有値:\")\n",
    "print(eigenvalues)\n",
    "\n",
    "print(\"固有ベクトル:\")\n",
    "print(eigenvectors)\n"
   ]
  }
