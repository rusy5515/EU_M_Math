   "source": [
    "import numpy as np\n",
    "\n",
    "A = np.array([\n",
    "    [1, 2, 3],\n",
    "    [1, 3, 2],\n",
    "    [3, 1, 2]\n",
    "])\n",
    "\n",
    "det_A = np.linalg.det(A)\n",
    "\n",
    "print(det_A)\n"
   ]
