   "source": [
    "標準正規分布に従う乱数を10個発生させろ。また、その中で、最小値、最大値合計を求めるプログラムをかけ。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "cdbd5e86",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "乱数 [-0.52549405 -0.02179544  1.58585891  2.14039594  0.64076978  0.1944723\n",
      "  0.30552871 -0.66991837 -0.16265186  0.58358462]\n",
      "最小値 -0.6699183702123582\n",
      "最大値 2.1403959426206973\n",
      "合計値 4.070750549400112\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "x = np.random.randn(10)\n",
    "\n",
    "minimum = np.min(x)\n",
    "maximum = np.max(x)\n",
    "total = np.sum(x)\n",
    "\n",
    "print(\"乱数\",x)\n",
    "print(\"最小値\",minimum)\n",
    "print(\"最大値\",maximum)\n",
    "print(\"合計値\",total)"
   ]
  }
 ],
